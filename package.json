{
  "name": "viblack",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build:app": "tsc -p tsconfig.json",
    "build:evaluator": "tsc -p tools/evaluator/tsconfig.json",
    "build": "npm run build:app && npm run build:evaluator",
    "check:app": "tsc --noEmit -p tsconfig.json",
    "check:evaluator": "tsc --noEmit -p tools/evaluator/tsconfig.json",
    "check": "npm run check:app && npm run check:evaluator",
    "eval:prompt": "npm run build && node dist/tools/evaluator/run.js",
    "start": "npm run build && electron .",
    "test:e2e": "npm run build && playwright test",
    "verify": "npm run check && npm run build && npm run test:e2e"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Codex CLI-powered AI workspace messenger",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "electron": "^40.6.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  }
}
